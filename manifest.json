{
  "manifest_version": 3,
  "name": "Have You Solved Today?",
  "version": "1.0.0",
  "description": "Track your daily LeetCode & Codeforces solving streak.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
"background": {
  "scripts": ["background.js"]
},
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://codeforces.com/*",
    "https://leetcode.com/*",
    "https://alfa-leetcode-api.onrender.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
